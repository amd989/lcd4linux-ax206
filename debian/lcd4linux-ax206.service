[Unit]
Description=LCD4Linux display daemon for AX206 USB displays
After=network.target

[Service]
Type=simple
ExecStartPre=/bin/sh -c 'test -f /etc/lcd4linux/lcd4linux.conf || { echo "No config found. Copy an example: sudo cp /etc/lcd4linux/examples/dpf_320x240.conf /etc/lcd4linux/lcd4linux.conf"; exit 1; }'
ExecStart=/usr/bin/lcd4linux -F -c /etc/lcd4linux/lcd4linux.conf
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
