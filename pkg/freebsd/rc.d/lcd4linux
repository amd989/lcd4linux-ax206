#!/bin/sh

# PROVIDE: lcd4linux
# REQUIRE: LOGIN usbd
# KEYWORD: shutdown

. /etc/rc.subr

name="lcd4linux"
rcvar="lcd4linux_enable"

: ${lcd4linux_enable:="NO"}
: ${lcd4linux_config:="/usr/local/etc/lcd4linux/lcd4linux.conf"}

command="/usr/local/bin/lcd4linux"
command_args="-F -f ${lcd4linux_config}"

# Working directory for resolving relative theme paths (fonts/, themes/)
: ${lcd4linux_chdir:="/usr/local/share/lcd4linux"}

pidfile="/var/run/${name}.pid"
start_cmd="lcd4linux_start"
stop_cmd="lcd4linux_stop"

lcd4linux_start()
{
    if [ ! -f "${lcd4linux_config}" ]; then
        echo "Error: ${lcd4linux_config} not found."
        echo "Run: lcd4linux-theme apply SimpleBlue"
        return 1
    fi
    echo "Starting ${name}."
    /usr/sbin/daemon -p ${pidfile} -f /bin/sh -c "cd '${lcd4linux_chdir}' && exec ${command} ${command_args}"
}

lcd4linux_stop()
{
    if [ -f "${pidfile}" ]; then
        echo "Stopping ${name}."
        kill $(cat ${pidfile}) 2>/dev/null
        rm -f ${pidfile}
    fi
}

load_rc_config $name
run_rc_command "$1"
