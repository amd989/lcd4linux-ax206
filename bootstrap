#!/bin/sh

# $Id$
# $URL$

# exit on errors
set -e

# set nicer prompt for tracing
PS4="$0:\$LINENO> "
set -x

# automake requires ChangeLog — point to CHANGELOG.md if it exists
[ ! -f ChangeLog ] && [ -f CHANGELOG.md ] && ln -s CHANGELOG.md ChangeLog

# m4/ must exist before aclocal runs (configure.ac references it via AC_CONFIG_MACRO_DIR)
mkdir -p m4

# Build aclocal include flags for non-standard m4 macro paths (FreeBSD: /usr/local/share/aclocal)
ACLOCAL_ARGS="-I m4"
[ -d /usr/local/share/aclocal ] && ACLOCAL_ARGS="$ACLOCAL_ARGS -I /usr/local/share/aclocal"

aclocal $ACLOCAL_ARGS
libtoolize --copy --force
autoheader
automake --add-missing --copy --foreign
autoconf

